DATABASE_URL=postgresql+psycopg://resol:resol@localhost:5432/resol_backend
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
# Fixed policy values (runtime ignores env override; documented here for visibility)
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_BUCKET=resol-private-bucket
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me
CONTENT_PIPELINE_API_KEY=change-me-content-pipeline-api-key
AI_GENERATION_PROVIDER=disabled
AI_GENERATION_API_KEY=change-me-ai-provider-key
AI_MOCK_EXAM_MODEL=mock-exam-model-name
AI_MOCK_EXAM_PROMPT_TEMPLATE_VERSION=v1
AI_CONTENT_PROVIDER=disabled
AI_CONTENT_API_KEY=change-me-ai-content-provider-key
AI_CONTENT_MODEL=content-generation-model-name
AI_CONTENT_PROMPT_TEMPLATE_VERSION=v1
AI_CONTENT_MAX_TARGETS_PER_RUN=12
AI_CONTENT_MAX_CANDIDATES_PER_RUN=40
AI_CONTENT_MAX_ESTIMATED_COST_USD=5.0
AI_CONTENT_DEFAULT_DRY_RUN=true
AI_CONTENT_ESTIMATED_INPUT_COST_PER_MILLION_TOKENS=0.5
AI_CONTENT_ESTIMATED_OUTPUT_COST_PER_MILLION_TOKENS=1.5
AI_PROVIDER_HTTP_TIMEOUT_SECONDS=20
AI_OPENAI_BASE_URL=https://api.openai.com
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_ARTIFACT_RETENTION_DAYS=30
STRIPE_WEBHOOK_SECRET=change-me-stripe-webhook-secret
APP_STORE_SHARED_SECRET=change-me-app-store-shared-secret
APP_STORE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
APP_STORE_SANDBOX_VERIFY_URL=https://sandbox.itunes.apple.com/verifyReceipt
